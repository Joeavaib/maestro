{
  "ollama_host": "http://127.0.0.1:11434",
  "ollama_timeout_s": 300,
  "validator_backend": "ollama",
  "validator_model": "raven_primary",
  "validator_seed": 42,
  "validator_max_new_tokens": 512,
  "strict_mode": false,
  "max_retries": 3,
  "abs_max_turns": 8,
  "execution_mode": "unsafe-local",
  "apply_to_repo": true,
  "allow_renames": false,
  "parallel_decompose": false,
  "validator_input_cap": 24000,
  "validator_max_tool_calls": 10,
  "checks": [],
  "agents": {
    "bld": {"model": "tree_fast"},
    "imp": {"model": "tree_deepseek"},
    "tst": {"model": "tree_strong"}
  }
}
