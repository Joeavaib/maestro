# Maestro Local Configuration
# Do not place real API keys or passwords in this file.
# Copy this file to .env and fill in your actual values.

# Ollama / vLLM API Settings
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT_S=300

# WebUI Settings (Future)
WEBUI_PORT=3000
WEBUI_HOST=0.0.0.0
# SECRET_KEY=generate-a-secure-secret-for-jwt-tokens

# Advanced Maestro Settings
LOG_LEVEL=INFO
# MAX_CONCURRENT_AGENTS=3
